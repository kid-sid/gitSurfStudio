# ──────────────────────────────────────────────────────────────────────────────
# GitSurf Studio — Environment Variables
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Required: OpenAI API key for the AI engine
OPENAI_API_KEY=sk-...

# Optional: GitHub Personal Access Token (enables git clone + fork features)
GITHUB_TOKEN=github_pat_...

# Optional: GitHub OAuth App credentials (enables /auth/login flow)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Tavily API key (enables WebSearchTool)
TAVILY_API_KEY=tvly-...

# Optional: Use OpenAI for embeddings instead of the free local model
# EMBEDDING_PROVIDER=openai

# Optional: Google API key (alternative LLM provider)
GOOGLE_API_KEY=

# Optional: Supabase — used for persistent memory and security event logging
# Get from: Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key
