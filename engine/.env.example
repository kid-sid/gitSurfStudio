GITHUB_TOKEN=your_github_token_here
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
# Embedding provider: 'local' (free, default) or 'openai' (paid)
EMBEDDING_PROVIDER=local

# Supabase — used by the security event logger to store injection attempts
# Get SUPABASE_URL from: Dashboard → Settings → API → Project URL
# Get SUPABASE_SERVICE_KEY from: Dashboard → Settings → API → service_role (secret)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key
