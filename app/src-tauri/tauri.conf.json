{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/tauri.schema.json",
  "productName": "GitSurf Studio",
  "version": "0.1.0",
  "identifier": "com.gitsurf.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "GitSurf Studio",
    "windows": [
      {
        "title": "GitSurf Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
